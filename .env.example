# AInextleveler local-only v1
# Shared keys (Anthropic, Voyage) live in ~/Code/.env.shared and load via next.config.ts.
# This file holds AInextleveler-specific config.

# Auth — single password for the local app. CHANGE THIS.
AUTH_PASSWORD=changeme
# 32+ char random string for iron-session cookie sealing. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=replace_with_32_byte_hex_string_replace_with_32_byte_hex_string

# Database — local pgvector via docker compose, or Railway hosted.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/ainextleveler

# GitHub PAT, scope: public_repo (per eng review Q4).
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_replace_me

# Filesystem scan roots (per eng review A8 — paths validated via realpath).
# These are the only roots the infra scanner is allowed to read.
HOME_DIR=/Users/your-username
CODE_DIR=/Users/your-username/Code

# Verify ~/Code/.env.shared has these (do not duplicate here):
# ANTHROPIC_API_KEY=sk-ant-...
# VOYAGE_API_KEY=pa-...
